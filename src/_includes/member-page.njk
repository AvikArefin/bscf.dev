---
layout: base.njk
---

<div class="archive-container">
  <div class="archive-intro">
    <span class="archive-tag">Team Member</span>
    <h1 class="archive-title">{{ member.name }}</h1>
    <div class="archive-line"></div>
  </div>

  <section class="member-detail-grid">
    <div class="member-meta">
      <div class="member-image-frame">
        <img src="{{ member.image }}" alt="{{ member.name }}">
      </div>
      <div class="member-specs">
        <p class="member-role">{{ member.role }}</p>
        {% if member.department %}
          <p class="member-dept">{{ member.department }}</p>
        {% endif %}
      </div>
    </div>

    <div class="member-bio">
        <div class="bio-content">{{ member.bio }}</div>
    </div>
  </section>
</div>

<style>
  :root {
    --border-color: #eaeaea;
    --text-main: #1a1a1a;
    --text-muted: #666;
    --accent: #000;
    --max-width: 1148px;
  }

  .archive-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 24px;
    text-align: left;
  }

  /* HEADER SECTION */
  .archive-intro {
    margin-bottom: 60px;
  }

  .archive-tag {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #a0a0a0;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .archive-title {
    font-size: clamp(2.5rem, 5vw, 3.2rem);
    font-weight: 800;
    margin: 0 0 20px 0;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .archive-line {
    height: 4px;
    width: 60px;
    background: var(--accent);
  }

  /* GRID SYSTEM */
  .member-detail-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 80px;
    align-items: start;
  }

  /* IMAGE COLUMN */
  .member-image-frame {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px;
    background: #f9f9f9;
    margin-bottom: 2rem;
    border: 1px solid var(--border-color);
  }

  .member-image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-specs {
    border-left: 2px solid var(--border-color);
    padding-left: 1.5rem;
  }

  .member-role {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .member-dept {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: italic;
  }


  .bio-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
    white-space: pre-wrap;
    text-align: justify;
    margin-top: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 992px) {
    .member-detail-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .member-image-frame {
      max-width: 340px;
    }
  }

  @media (max-width: 768px) {
    .archive-container {
      padding: 40px 20px;
    }
    
    .archive-intro {
      margin-bottom: 40px;
    }
    
    .member-image-frame {
      max-width: 100%;
    }
  }
</style>