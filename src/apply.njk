---
layout: base.njk
title: All recruitments
permalink: /apply/
---

<div class="archive-container">
  <div class="archive-intro">
    <span class="archive-tag">Careers</span>
    <h1 class="archive-title">{{ title }}</h1>
    <div class="archive-line"></div>
  </div>

  <div class="recruitment-list">
    {% for recruitment in collections.recruitments %}
    <a href="{{ recruitment.url }}" class="recruitment-card">
      <div class="card-image-wrapper">
        {% if recruitment.data.featured %}
          <img src="{{ recruitment.data.featured }}" alt="{{ recruitment.data.title }}" loading="lazy">
        {% else %}
          <div class="image-placeholder"></div>
        {% endif %}
      </div>
      
      <div class="card-content">
        <h2 class="card-title">{{ recruitment.data.title }}</h2>
        <p class="card-description">{{ recruitment.data.description }}</p>
        <span class="card-link">Apply Now →</span>
      </div>
    </a>
    {% endfor %}
  </div>
</div>

<style>
:root {
    --border-color: #eaeaea;
    --text-main: #1a1a1a;
    --text-muted: #666;
    --accent: #000;
    --max-width: 1148px; /* Changed from 1200px to match Recruitments */
  }

  .archive-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 24px;
  }

  .archive-intro {
    margin-bottom: 60px;
  }

  .archive-tag {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #a0a0a0;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .archive-title {
    font-size: clamp(2.5rem, 5vw, 3.2rem);
    font-weight: 800;
    margin: 0 0 20px 0;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .archive-line {
    height: 4px;
    width: 60px;
    background: var(--accent);
  }

  /* GRID */
  .recruitment-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  /* CARD STYLING */
  .recruitment-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .recruitment-card:hover {
    transform: translateY(-8px);
    border-color: #d1d1d1;
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f9f9f9;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .recruitment-card:hover .card-image-wrapper img {
    transform: scale(1.05);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, #f3f3f3, #e9e9e9);
  }

  .card-content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--text-main);
  }

  .card-description {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3; /* Slightly longer for job descriptions */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link {
    margin-top: auto;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .recruitment-card:hover .card-link {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .archive-container { padding: 40px 20px; }
    .archive-intro { margin-bottom: 40px; }
    .recruitment-list { grid-template-columns: 1fr; }
  }
</style>